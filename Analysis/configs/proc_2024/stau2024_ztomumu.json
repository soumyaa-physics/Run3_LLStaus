    "jet_eta_min"  : -2.1,
    "jet_eta_max"  :  2.1,
    "jet_jetId"    :  6, // jetId>=6 pass lepton veto and tight id, jetId>=2 pass tight id
    "dphi_j1j2"    :  0.5,
    "jet_dxy_min"  :  0.5, // to test MC/Data modeling
